  "privacyPolicyTitle": "Política de Privacidad",
  "privacyPolicyIntro": "En Brainova, tu privacidad es nuestra prioridad.",
  "privacyPolicyDataCollectionTitle": "Recopilación de Datos",
  "privacyPolicyDataCollectionBody": "Solo recopilamos los datos necesarios para rastrear tu progreso y proporcionar recomendaciones personalizadas.",
  "privacyPolicyDataSecurityTitle": "Seguridad de los Datos",
