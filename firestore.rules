rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Rules for User Profiles and their subcollections
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Rules for Activity Logs
    match /activities/{activityId} {
      // Allow list if authenticated (required for dashboard and user history)
      allow list: if isSignedIn();
      
      // Allow specific access
      allow get: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Rules for Content Diet
    match /content_diet/{entryId} {
      allow read, write: if isSignedIn();
    }
    
    // Publicly readable content collections (Restores Home Screen UI)
    match /badges/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /challenges/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
      
      // Allow participants subcollection specifically for owners
      match /participants/{participantId} {
        allow read, write: if isOwner(participantId) || isAdmin();
      }
    }
    
    // Admin specific collections
    match /admin_logs/{document=**} {
      allow read, write: if isAdmin();
    }
    
    // System stats (Used by admin dashboard)
    match /daily_system_stats/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Default fallback
    match /{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
